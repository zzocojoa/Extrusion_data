# Copy this file to `.env` and fill in values.
# For local development of process_and_upload.py

# Project URL (both client and server)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Server-only secret (DO NOT ship to client desktops)
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

# Client-side key for calling Edge Functions (safe to distribute)
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: override Edge Function URL; if empty, derived from SUPABASE_URL
# EDGE_FUNCTION_URL=https://YOUR-PROJECT-REF.supabase.co/functions/v1/upload-metrics

# UI language example
# UI_LANGUAGE=ko

