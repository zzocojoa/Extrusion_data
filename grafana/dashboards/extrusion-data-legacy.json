      "targets": [
        {
          "dataset": "postgres",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH base AS (\n    SELECT\n      date_trunc('day', start_time AT TIME ZONE 'Asia/Seoul') AT TIME ZONE 'Asia/Seoul' AS day,\n      die_id,\n      die_number,\n      start_time,\n      end_time,\n      id\n    FROM public.tb_work_log\n    WHERE start_time <= $__timeTo()\n      AND COALESCE(end_time, start_time) >= $__timeFrom()\n  ),\n  ordered AS (\n    SELECT\n      *,\n      ROW_NUMBER() OVER (PARTITION BY day, die_id ORDER BY start_time, end_time, id) AS seq\n    FROM base\n  )\n  SELECT\n    day AS \"일자\",\n    die_id AS \"die_id\",\n    COUNT(*) AS \"금형 기록수\",\n    COUNT(DISTINCT die_number) FILTER (WHERE die_number IS NOT NULL) AS \"금형 종류수\",\n    STRING_AGG(die_number::text, ',' ORDER BY seq)\n      FILTER (WHERE die_number IS NOT NULL) AS \"die_number_전체목록\",\n    STRING_AGG(\n      to_char(start_time AT TIME ZONE 'Asia/Seoul', 'HH24:MI') || '~' ||\n      to_char(end_time   AT TIME ZONE 'Asia/Seoul', 'HH24:MI'),\n      ', ' ORDER BY seq\n    ) AS \"시간_목록\"\n  FROM ordered\n  GROUP BY 1, 2\n  ORDER BY 1, MIN(start_time AT TIME ZONE 'Asia/Seoul'), die_id;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "DW에 따른 번호",
      "type": "barchart"
