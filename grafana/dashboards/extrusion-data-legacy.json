          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    date_trunc('day', start_time) AS time,\n    AVG(yield_rate) AS yield_rate_avg,\n    COALESCE(SUM(defect_bubble), 0) AS \"기포\",\n    COALESCE(SUM(defect_tearing), 0) AS \"뜯김\",\n    COALESCE(SUM(defect_white_black_line), 0) AS \"백선/흑선\",\n    COALESCE(SUM(defect_oxide), 0) AS \"산화물\",\n    COALESCE(SUM(defect_scratch), 0) AS \"스크래치\",\n    COALESCE(SUM(defect_bend), 0) AS \"휨\",\n    COALESCE(SUM(defect_dimension), 0) AS \"치수\",\n    COALESCE(SUM(defect_line), 0) AS \"라인\",\n    COALESCE(SUM(defect_etc), 0) AS \"기타\",\n    COALESCE(SUM(defect_bubble), 0)\n    + COALESCE(SUM(defect_tearing), 0)\n    + COALESCE(SUM(defect_white_black_line), 0)\n    + COALESCE(SUM(defect_oxide), 0)\n    + COALESCE(SUM(defect_scratch), 0)\n    + COALESCE(SUM(defect_bend), 0)\n    + COALESCE(SUM(defect_dimension), 0)\n    + COALESCE(SUM(defect_line), 0)\n    + COALESCE(SUM(defect_etc), 0) AS total_defects\n  FROM public.tb_work_log\n  WHERE $__timeFilter(start_time)\n  GROUP BY 1\n  ORDER BY 1;",
