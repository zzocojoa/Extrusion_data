          "rawQuery": true,
          "rawSql": "WITH params AS (\n  SELECT CASE\n    WHEN $__to - $__from <= 518400000 THEN NULL\n    ELSE GREATEST(\n      $__interval_ms::bigint,\n      CEIL((($__to - $__from)::numeric) / 500000.0)::bigint\n    )\n  END AS bucket_ms\n)\nSELECT\n  CASE\n    WHEN params.bucket_ms IS NULL THEN src.\"timestamp\"\n    ELSE to_timestamp(floor(extract(epoch from src.\"timestamp\") * 1000.0 / params.bucket_ms) * params.bucket_ms / 1000.0)\n  END AS \"time\",\n  src.die_id,\n  AVG(src.temperature) AS \"temperature\",\n  AVG(src.main_pressure) AS \"main_pressure\",\n  AVG(src.billet_length) AS \"billet_length\",\n  AVG(src.container_temp_front) AS \"container_temp_front\",\n  AVG(src.container_temp_rear) AS \"container_temp_rear\",\n  MAX(src.production_counter) AS \"production_counter\",\n  AVG(src.current_speed) AS \"current_speed\",\n  AVG(src.extrusion_end_position) AS \"extrusion_end_position\",\n  AVG(src.billet_temp) AS \"billet_temp\",\n  AVG(src.at_pre) AS \"at_pre\",\n  AVG(src.at_temp) AS \"at_temp\"\nFROM public.mv_optimized_metrics_work_log AS src\nCROSS JOIN params\nWHERE $__timeFilter(src.\"timestamp\")\nGROUP BY 1, 2\nORDER BY 1 ASC",
          "refId": "A",
          "sql": {
