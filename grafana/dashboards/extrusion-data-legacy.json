        {
          "dataset": "postgres",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH params AS (\n  SELECT CASE\n    WHEN $__to - $__from <= 345600000 THEN NULL\n    ELSE GREATEST(\n      $__interval_ms::bigint,\n      CEIL((($__to - $__from)::numeric) / 700000.0)::bigint\n    )\n  END AS bucket_ms\n)\nSELECT\n  CASE\n    WHEN params.bucket_ms IS NULL THEN src.timestamp\n    ELSE to_timestamp(floor(extract(epoch from src.timestamp) * 1000.0 / params.bucket_ms) * params.bucket_ms / 1000.0)\n  END AS \"time\",\n  AVG(src.temperature) AS \"?????\",\n  AVG(src.main_pressure) AS \"????\",\n  AVG(src.billet_length) AS \"????\",\n  AVG(src.container_temp_front) AS \"??????-?\",\n  AVG(src.container_temp_rear) AS \"??????-?\",\n  MAX(src.production_counter) AS \"????\",\n  AVG(src.current_speed) AS \"????\",\n  AVG(src.extrusion_end_position) AS \"?? ? ??\",\n  AVG(src.billet_temp) AS \"??????\",\n  AVG(src.at_pre) AS \"????\",\n  AVG(src.at_temp) AS \"????\"\nFROM public.all_metrics AS src\nCROSS JOIN params\nWHERE $__timeFilter(src.timestamp)\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
