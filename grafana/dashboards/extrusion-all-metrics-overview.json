      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "extrusion-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with filtered as (\n  select *\n  from public.mv_optimized_metrics_work_log src\n  where $__timeFilter(\"timestamp\")\n    and src.die_id in (${die_id:sqlstring})\n), cycle_stats as (\n  select\n    die_id,\n    calc_cycle_id,\n    count(*) as cycle_rows,\n    max(coalesce(_applied_offset, 0)) as offset_rows,\n    avg(abs(temperature - original_temperature)) as cycle_abs_diff_avg,\n    percentile_cont(0.9) within group (\n      order by abs(temperature - original_temperature)\n    ) as cycle_abs_diff_p90,\n    min(\"timestamp\") as cycle_start,\n    max(\"timestamp\") as cycle_end\n  from filtered src\n  group by die_id, calc_cycle_id\n)\nselect\n  cycle_start,\n  cycle_end,\n  die_id,\n  calc_cycle_id,\n  cycle_rows,\n  offset_rows,\n  round(cycle_abs_diff_avg::numeric, 4) as cycle_abs_diff_avg,\n  round(cycle_abs_diff_p90::numeric, 4) as cycle_abs_diff_p90,\n  case\n    when offset_rows = 299 and cycle_abs_diff_avg >= 10 then 'offset_299_and_diff_10'\n    when offset_rows = 299 then 'offset_299'\n    when cycle_abs_diff_avg >= 10 then 'diff_10'\n    else 'normal'\n  end as suspect_reason\nfrom cycle_stats\nwhere offset_rows = 299\n   or cycle_abs_diff_avg >= 10\norder by cycle_abs_diff_avg desc nulls last, offset_rows desc, cycle_rows desc;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [],
            "limit": 50
          }
        }
