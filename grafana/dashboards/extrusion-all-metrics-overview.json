          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with filtered as (\n  select *\n  from public.mv_optimized_metrics_work_log src\n  where $__timeFilter(\"timestamp\")\n    and src.die_id in (${die_id:sqlstring})\n), cycle_stats as (\n  select\n    die_id,\n    calc_cycle_id,\n    count(*) as cycle_rows,\n    max(coalesce(_applied_offset, 0)) as offset_rows,\n    avg(abs(temperature - original_temperature)) as cycle_abs_diff_avg\n  from filtered\n  group by die_id, calc_cycle_id\n), per_die as (\n  select\n    die_id,\n    count(*) as cycle_count,\n    count(*) filter (\n      where offset_rows = 299 or cycle_abs_diff_avg >= 10\n    ) as suspect_cycle_count,\n    round(\n      100.0 * count(*) filter (\n        where offset_rows = 299 or cycle_abs_diff_avg >= 10\n      ) / count(*),\n      2\n    ) as suspect_cycle_pct,\n    round(avg(offset_rows)::numeric, 2) as avg_offset_rows,\n    round(avg(cycle_abs_diff_avg)::numeric, 4) as avg_cycle_abs_diff,\n    round(avg(cycle_rows)::numeric, 2) as avg_cycle_rows\n  from cycle_stats\n  group by die_id\n)\nselect *\nfrom per_die\nwhere suspect_cycle_count > 0\norder by suspect_cycle_pct desc, suspect_cycle_count desc, avg_cycle_abs_diff desc;",
          "refId": "A",
